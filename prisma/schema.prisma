generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?   @db.Text

  heroImageId String?
  heroImage   MediaAsset? @relation("ProjectHero", fields: [heroImageId], references: [id], onDelete: SetNull)

  published   Boolean   @default(false)
  publishedAt DateTime?

  seoTitle       String?
  seoDescription String?
  ogImageId      String?
  ogImage        MediaAsset? @relation("ProjectOg", fields: [ogImageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blocks      ContentBlock[]
  canvasItems HomepageCanvasItem[]

  @@index([slug])
  @@index([published, publishedAt])
}

// ─── Content Blocks ───────────────────────────────────────────────────────────

model ContentBlock {
  id        String    @id @default(cuid())
  projectId String
  type      BlockType
  order     Int
  payload   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, order])
}

enum BlockType {
  INTRO
  RICH_TEXT
  FULL_WIDTH_IMAGE
  IMAGE_TEXT
  PORTRAIT_IMAGE
  LANDSCAPE_IMAGE
  GALLERY
  QUOTE
  DIVIDER
  SPACER
}

// ─── Homepage Canvas ──────────────────────────────────────────────────────────

model HomepageCanvasItem {
  id        String  @id @default(cuid())
  projectId String?
  imageId   String

  xPercent      Float @default(0)
  yPercent      Float @default(0)
  widthPercent  Float @default(20)
  heightPercent Float @default(20)
  rotation      Float @default(0)
  zIndex        Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  image   MediaAsset @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([zIndex])
}

// ─── Media ────────────────────────────────────────────────────────────────────

model MediaAsset {
  id            String  @id @default(cuid())
  cloudinaryId  String  @unique
  cloudinaryUrl String
  format        String
  width         Int
  height        Int
  bytes         Int
  altText       String?
  caption       String?

  createdAt DateTime @default(now())

  heroProjects  Project[]            @relation("ProjectHero")
  ogProjects    Project[]            @relation("ProjectOg")
  canvasItems   HomepageCanvasItem[]
  galleryImages GalleryImage[]       @relation("GalleryImageAsset")

  @@index([createdAt])
}

// ─── Gallery ──────────────────────────────────────────────────────────────────

enum GalleryMediaType {
  PHOTO
  VIDEO
}

model GalleryImage {
  id          String  @id @default(cuid())
  imageId     String
  image       MediaAsset @relation("GalleryImageAsset", fields: [imageId], references: [id], onDelete: Cascade)

  altText     String
  caption     String?
  description String?  @db.Text
  category    String?
  mediaType   GalleryMediaType @default(PHOTO)

  order     Int     @default(0)
  published Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([category])
  @@index([published])
}

// ─── Notes ────────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  readTime  String   @default("2 min read")
  published Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
}

